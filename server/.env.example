# ============================================================
#  Swachhta & LiFE Dashboard — Environment Configuration
# ============================================================
#
# STEP 1: Copy this file and rename it to ".env"
# STEP 2: Fill in each value below
#
# ============================================================

# --- Server ---
PORT=3001
NODE_ENV=development

# --- JWT Secret (make this a long random string) ---
JWT_SECRET=swachhta-super-secret-jwt-key-change-me-2024

# --- Google Gemini AI (FREE tier) ---
# Get your free key at: https://aistudio.google.com/app/apikey
# Free quota: 15 requests/minute, 1 million tokens/day
GEMINI_API_KEY=your_gemini_api_key_here

# --- Gmail Email Sender (FREE) ---
# Use your Gmail address
GMAIL_USER=your_email@gmail.com
# Generate App Password at: Google Account → Security → 2-Step Verification → App Passwords
# App name: "Swachhta Dashboard"
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- Frontend URL (for CORS) ---
FRONTEND_URL=http://localhost:3001
